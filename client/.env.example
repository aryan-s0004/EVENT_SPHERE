# ─────────────────────────────────────────────────────────────────────────────
# Client (Vite/React) environment variables
#
# Copy to .env and fill in real values.
# Add these in Vercel → Project Settings → Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to the Express API (must include /api prefix).
#
# Local development (Express running on port 5000):
#   VITE_API_BASE_URL=http://localhost:5000/api
#
# Production (backend deployed on Render):
#   VITE_API_BASE_URL=https://your-eventsphere-api.onrender.com/api
#
VITE_API_BASE_URL=http://localhost:5000/api

# Must match GOOGLE_CLIENT_ID in server/.env.
# If you see Google "origin_mismatch", add your deployed Vercel origin
# to GCP → Credentials → OAuth client → Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=
