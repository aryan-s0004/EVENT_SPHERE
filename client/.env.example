# ─────────────────────────────────────────────────────────────────────────────
# Client (Vite/React) environment variables
#
# Copy this file to .env and fill in real values.
# Vercel automatically reads these when set in Project Settings → Env Vars.
# ─────────────────────────────────────────────────────────────────────────────

# Using relative "/api" because backend runs on the same Vercel domain.
# This avoids CORS issues and works in production automatically.
# For local dev with `vercel dev`, keep this as /api.
# Only set to http://localhost:5000/api if running the backend separately.
VITE_API_BASE_URL=/api

# Leave empty to disable Google Sign-In on the frontend.
# Must match GOOGLE_CLIENT_ID in the root .env.
VITE_GOOGLE_CLIENT_ID=
