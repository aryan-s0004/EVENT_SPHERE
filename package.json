{
  "name": "eventsphere",
  "version": "1.0.0",
  "private": true,
  "description": "EventSphere — full-stack event management platform deployed on Vercel",
  "scripts": {
    "dev": "vercel dev",
    "build": "cd frontend && npm install && npm run build",
    "install:frontend": "cd frontend && npm install",
    "install:all": "npm install && cd frontend && npm install && cd backend && npm install",
    "start:backend": "npm --prefix backend run start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "seed:backend": "npm --prefix backend run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18.x"
  }
}
