# ─────────────────────────────────────────────────────────────────────────────
# Client (Vite/React) environment variables
#
# Copy to .env and fill in real values.
# Set these in Vercel → Project Settings → Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# Vercel (production + preview): leave as /api
#   Frontend and API share the same Vercel domain, so /api is same-origin.
# Local dev with `vercel dev`: also /api (proxy handled by Vercel CLI on :3000).
# Local dev with Vite only: /api (vite.config.js proxy forwards to :3000).
VITE_API_BASE_URL=/api

# Must match GOOGLE_CLIENT_ID in Vercel env vars.
# Leave blank to disable Google Sign-In.
VITE_GOOGLE_CLIENT_ID=
