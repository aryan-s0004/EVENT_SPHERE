# ─────────────────────────────────────────────────────────────────────────────
# EventSphere — Environment Variables
#
# HOW TO USE:
#   1. Copy this file to .env in the project root for local development
#   2. Add these same keys in Vercel → Project Settings → Environment Variables
#      before deploying.
#
# SECURITY: Never commit a real .env file to git.
#           Never hard-code secrets in source files.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → your cluster → Connect
MONGO_URI=


# ── Authentication (JWT) ──────────────────────────────────────────────────────
# Any long random string — run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRE=7d


# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used to send OTP emails for registration and password reset.
# For Gmail: use an App Password, not your regular Gmail password.
#   Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Set to "true" to log OTPs to the console instead of sending real emails.
# Useful during local development when SMTP is not configured.
OTP_CONSOLE_FALLBACK=true


# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Leave empty to disable Google Sign-In.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# IMPORTANT: After deployment, update Authorised JavaScript Origins and
#            Redirect URIs in Google Cloud Console to your Vercel domain.
#            localhost URLs will break Google login in production.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Admin Account (bootstrapped on first run) ─────────────────────────────────
# These credentials are used to seed the first admin account.
# Change ADMIN_PASSWORD before deploying to production.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production


# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Using relative "/api" because backend runs on the same Vercel domain.
# This avoids CORS issues and works in production automatically.
# Do NOT change this for Vercel deployment — leave it as /api.
# Only override for local development if you run the backend separately.
VITE_API_BASE_URL=/api

# Must match GOOGLE_CLIENT_ID above (used by the React Google OAuth provider).
VITE_GOOGLE_CLIENT_ID=
