# ─────────────────────────────────────────────────────────────────────────────
# EventSphere — Environment Variables
#
# SETUP:
#   Local:      cp .env.example .env  →  fill in real values  →  never commit .env
#   Production: Add each key in Vercel → Project Settings → Environment Variables
#
# SECURITY: Never commit secrets. Never hard-code values in source files.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# MongoDB Atlas → cluster → Connect → Drivers → copy the URI.
# Format: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/<dbname>
# IMPORTANT: Atlas Network Access must include 0.0.0.0/0 (allow from anywhere).
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/eventsphere?retryWrites=true&w=majority


# ── JWT (REQUIRED) ────────────────────────────────────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_character_random_string
JWT_EXPIRE=7d


# ── Email / SMTP (optional but OTPs won't be emailed without it) ──────────────
# Gmail → create an App Password at https://myaccount.google.com/apppasswords
# Set OTP_CONSOLE_FALLBACK=true in dev so OTPs appear in the console instead.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
OTP_CONSOLE_FALLBACK=true


# ── Google OAuth (optional — enables Google Sign-In) ─────────────────────────
# GCP Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#
# Authorised JavaScript origins — add ALL of these:
#   http://localhost:5173
#   https://<your-project>.vercel.app
#
# Authorised redirect URIs — add ALL of these:
#   http://localhost:5173
#   https://<your-project>.vercel.app
#
# Leave GOOGLE_CLIENT_ID empty to disable Google Sign-In entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Admin seed ────────────────────────────────────────────────────────────────
# After first deploy, run once: node scripts/seed-admin.js
# Change ADMIN_PASSWORD before going live — the default is deliberately weak.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@eventsphere.com
ADMIN_PASSWORD=Change_me_immediately_1!


# ── Frontend variables (Vite / React) ─────────────────────────────────────────
# VITE_ prefix is REQUIRED — Vite strips variables without it at build time.
#
# Vercel (production + preview): leave as /api — frontend and API share the
#   same Vercel domain so no CORS issues arise and no full URL is needed.
# Local dev with Express backend: http://localhost:5000/api
VITE_API_BASE_URL=/api

# Must match GOOGLE_CLIENT_ID above exactly.
VITE_GOOGLE_CLIENT_ID=
